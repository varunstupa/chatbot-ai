# Keep the build context small and avoid leaking local state into the image.
.git
.gitignore
.venv
venv
__pycache__
**/__pycache__
*.py[cod]
*.egg-info
.eggs
dist
build

# Secrets — provided at runtime via env_file / -e, never baked into the image.
.env

# Generated runtime data — recreated inside the container / mounted as volumes.
# NOTE: data/uploads is intentionally NOT ignored so the bundled seed documents
# get baked into the image and ingested on first run (see docker/entrypoint.sh).
data/chroma/
data/chroma_website/
data/ticket_attachments/
data/ticket_sessions/
data/demo_sessions/
crawler/node_modules/
crawler/storage/
crawler/.tmp/
node_modules/
.cache/

# Docs / editor / OS noise
*.md
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db
